* text=auto

# Keep source and docs LF-consistent across platforms
*.md text eol=lf
*.json text eol=lf
.env* text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.svg text eol=lf

# Windows-native scripts usually expect CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
